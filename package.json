{
  "name": "git-watch",
  "version": "0.1.0",
  "description": "Git リポジトリの upstream 更新を定期的に検知し、通知する CLI ツール",
  "type": "module",
  "bin": {
    "git-watch": "./bin/git-watch.js"
  },
  "files": [
    "dist",
    "bin"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --test --experimental-test-coverage",
    "watch": "tsc --watch",
    "prepare": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TsubasaKawajiri/git-watch.git"
  },
  "keywords": [
    "git",
    "watch",
    "upstream",
    "notification"
  ],
  "author": "TsubasaKawajiri",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/node-notifier": "^8.0.5",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "node-notifier": "^10.0.1"
  }
}
